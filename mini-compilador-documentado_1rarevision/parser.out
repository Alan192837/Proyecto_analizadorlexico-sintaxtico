    (19) si_stmt -> . SI PAR_IZQ expr PAR_DER LLA_IZQ lista_sentencias LLA_DER
    (12) tipo -> . ENTERO
    (13) tipo -> . CADENA_TIPO
    (14) tipo -> . LOGICO_TIPO

