    (18) si_stmt -> SI PAR_IZQ expr PAR_DER LLA_IZQ lista_sentencias LLA_DER SINO LLA_IZQ lista_sentencias . LLA_DER
    (2) lista_sentencias -> lista_sentencias . sentencia
    (4) lista_sentencias -> lista_sentencias . error PUNTOCOM
